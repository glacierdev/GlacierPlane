# Copy this file to `.env` and fill in the required values.

# Webhook secret used to validate incoming GitHub webhook URLs.
# Generate one with: openssl rand -hex 32
WEBHOOK_SECRET=

# Host port the control-plane is exposed on. Defaults to 80.
HOST_PORT=

# GitHub Personal Access Token (scope: repo:status, or repo for private repos).
# When set, build statuses are reported back to GitHub commits.
GITHUB_TOKEN=

# PostgreSQL credentials.
POSTGRES_USER=glacier
POSTGRES_PASSWORD=glacier123
POSTGRES_DB=glacier

# Logging level for the control-plane.
RUST_LOG=control_plane=info,tower_http=info
